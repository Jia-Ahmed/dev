      </div>

      {/* Modern Spotlight Effect */}
      <div 
        className="absolute inset-0 z-30 opacity-0 group-hover:opacity-30 pointer-events-none"
        style={{
          background: `radial-gradient(circle at ${mousePosition.x}px ${mousePosition.y}px, rgba(255,255,255,0.2) 0%, transparent 70%)`
        }}
      />
    </div>
  );
