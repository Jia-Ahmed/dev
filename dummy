import React, { useState } from 'react';
import Link from 'next/link';
// Error fix karne ke liye NextImage use karein
import NextImage from 'next/image'; 

export default function ServiceCard({ id, title, description, Icon, gradient, features, index, image }) {
  const [mousePosition, setMousePosition] = useState({ x: 0, y: 0 });

  const handleMouseMove = (e) => {
    const rect = e.currentTarget.getBoundingClientRect();
    setMousePosition({
      x: e.clientX - rect.left,
      y: e.clientY - rect.top
    });
  };

  return (
    <div 
      className="relative group h-[400px] w-full overflow-hidden rounded-3xl"
      onMouseMove={handleMouseMove}
      style={{ animationDelay: `${index * 150}ms` }}
    >
      {/* 1. Background Image Layer */}
      <div className="absolute inset-0 z-0 transition-transform duration-700 ease-in-out group-hover:scale-110">
        {image ? (
          <NextImage 
            src={image} 
            alt={title}
            fill
            className="object-cover"
            sizes="(max-width: 768px) 100vw, 33vw"
          />
        ) : (
          <div className={`w-full h-full bg-gradient-to-br ${gradient} opacity-40`} />
        )}
        {/* Dark Overlay - Jo hover par aur dark ho jayega */}
        <div className="absolute inset-0 bg-black/40 group-hover:bg-black/70 transition-colors duration-500" />
      </div>

      {/* 2. Initial State: Title & Icon (Center or Bottom) */}
      <div className="absolute inset-0 z-10 flex flex-col justify-end p-8 transition-all duration-500 group-hover:translate-y-[-20%] group-hover:opacity-0">
        <div className={`w-12 h-12 rounded-lg bg-gradient-to-br ${gradient} flex items-center justify-center mb-4 shadow-lg`}>
          <Icon className="w-6 h-6 text-white" />
        </div>
        <h3 className="text-3xl font-black text-white leading-tight">
          {title}
        </h3>
      </div>

      {/* 3. Hover State: Full Content (Slides up from bottom) */}
      <div className="absolute inset-0 z-20 flex flex-col justify-center p-8 translate-y-[100%] opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 ease-out">
        <div className={`w-16 h-16 rounded-2xl bg-gradient-to-br ${gradient} flex items-center justify-center mb-6`}>
          <Icon className="w-8 h-8 text-white" />
        </div>
        
        <h3 className="text-2xl font-bold text-teal-400 mb-4">{title}</h3>
        
        <p className="text-gray-200 mb-6 text-sm leading-relaxed line-clamp-3">
          {description}
        </p>

        <div className="flex flex-wrap gap-2 mb-8">
          {features.slice(0, 3).map((f, i) => (
            <span key={i} className="text-[10px] uppercase tracking-widest text-white/70 border-b border-teal-500/50">
              {f}
            </span>
          ))}
        </div>

        <Link href={`/service/${id}`}>
          <button className="w-fit px-6 py-2 bg-teal-500 text-white rounded-full font-bold text-sm hover:bg-teal-600 transition-colors">
            Get in Touch
